rules_version = '2';

// ===============================================================
// AAA-AI Firestore Security Rules
// ---------------------------------------------------------------
// Points are SERVER-AUTHORITATIVE. The Android app NEVER writes
// `points` or `premium_until` directly — all mutations go through
// the Cloudflare Worker (/api/points/add, guarded by APP_SHARED_SECRET,
// with D1 as the authoritative wallet). Firestore is a read-only
// display mirror for the client. The client may only create/read and
// edit its own PROFILE fields.
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Fields the client is permitted to write on its own profile.
    function profileFields() {
      return ['email', 'displayName', 'photoURL'];
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['points', 'email', 'displayName', 'photoURL', 'createdAt', 'premium_until'])
        && (data.points is int || data.points is float)
        && data.email is string && data.email.size() < 200
        && data.displayName is string && data.displayName.size() < 100
        && data.photoURL is string && data.photoURL.size() < 500;
    }

    match /users/{uid} {
      // Reads: owner only.
      allow read: if isOwner(uid);

      // Create: only the owner, with a valid initial shape.
      allow create: if isOwner(uid) && isValidUser(request.resource.data);

      // Update: client may ONLY change profile fields. It must NOT touch
      // points, premium_until, or createdAt. Server-side writers use
      // admin credentials (bypass these rules) so the Worker mirror still works.
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(profileFields())
        && (request.resource.data.email is string && request.resource.data.email.size() < 200)
        && (request.resource.data.displayName is string && request.resource.data.displayName.size() < 100)
        && (request.resource.data.photoURL is string && request.resource.data.photoURL.size() < 500);

      // Deletes are never permitted from clients.
      allow delete: if false;

      match /history/{id} {
        // Client may only append its own history; it cannot edit/delete entries.
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['endpointId', 'text', 'isUser', 'timestamp', 'kind'])
          && request.resource.data.text is string && request.resource.data.text.size() < 20000
          && request.resource.data.timestamp is int;
        allow update, delete: if false;
      }

      match /transactions/{id} {
        // Read-only on the client. Transactions are written server-side.
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }
    }
  }
}
