rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
//
// users/{uid}                          -> user wallet + profile
//   fields: points (number, required), email (string), displayName (string),
//           photoURL (string), createdAt (timestamp)
//   - points only writable by the owner; immutable for everyone else.
//
// users/{uid}/history/{id}             -> chat / gallery / text entries
//   fields: endpointId (string), text (string), isUser (bool), timestamp (number), kind (string)
//   - create/read/update/delete only by owner.
//
// users/{uid}/transactions/{id}        -> points earn/spend log
//   fields: type (string), amount (number), reason (string), timeMillis (number)
//   - create by owner only (append-only log); no updates/deletes.
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    function isValidUser(data) {
      return data.keys().hasOnly(['points','email','displayName','photoURL','createdAt'])
        && (data.points is int || data.points is float)
        && data.email is string && data.email.size() < 200
        && data.displayName is string && data.displayName.size() < 100
        && data.photoURL is string && data.photoURL.size() < 500;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && request.resource.data.keys().hasOnly(['points','email','displayName','photoURL'])
        && request.resource.data.points is int;

      match /history/{id} {
        allow read, write: if isOwner(uid);
      }

      match /transactions/{id} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['type','amount','reason','timeMillis'])
          && request.resource.data.type in ['earn','spend']
          && request.resource.data.amount is int
          && request.resource.data.reason is string && request.resource.data.reason.size() < 100;
        allow update, delete: if false;
      }
    }
  }
}
