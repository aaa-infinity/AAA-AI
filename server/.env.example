# Copy to server/.env and fill in. Never commit the real .env (gitignored).
# Used by: npm run secrets  (scripts/setup-secrets.sh)

# Telegram bot tokens
FREE_AI_BOT_TOKEN=
LOGIN_BOT_TOKEN=
ADMIN_BOT_TOKEN=
ADMIN_CHAT_ID=

# AI provider keys (server-side only, never shipped in the app)
GEMINI_KEY=
GROQ_KEY=
HF_KEY=

# Supabase mirror
SUPABASE_URL=
SUPABASE_ANON=
SUPABASE_SERVICE_ROLE=

# Guards privileged app->server routes (must match app KeySubmitter)
APP_SHARED_SECRET=

# Public AAA FREE AI Telegram channel (bot must be admin in the channel)
CHANNEL_ID=-1003932377927

# Google OAuth Web client (project aaa-free-ai) for YouTube control + sub verify
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public origin used to build OAuth redirect/deep links
PUBLIC_ORIGIN=https://aaa-ai-bot.aaateam.workers.dev
